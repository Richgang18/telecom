<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A1628">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#16213E"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?selectableItemBackgroundBorderless"
            android:tint="#DFE6E9" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Accent Conversion"
            android:textColor="#DFE6E9"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🇺🇸 EN"
            android:textColor="#0984E3"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Pipeline flow steps -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/step1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Your\nVoice"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="#DFE6E9"
                    android:background="@drawable/step_bg"
                    android:padding="6dp"
                    android:alpha="0.3" />

                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="›" android:textColor="#636E72" android:gravity="center" android:textSize="18sp"/>

                <TextView
                    android:id="@+id/step2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Deepgram\nSTT"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="#DFE6E9"
                    android:background="@drawable/step_bg"
                    android:padding="6dp"
                    android:alpha="0.3" />

                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="›" android:textColor="#636E72" android:gravity="center" android:textSize="18sp"/>

                <TextView
                    android:id="@+id/step3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cartesia\nTTS"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="#DFE6E9"
                    android:background="@drawable/step_bg"
                    android:padding="6dp"
                    android:alpha="0.3" />

                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="›" android:textColor="#636E72" android:gravity="center" android:textSize="18sp"/>

                <TextView
                    android:id="@+id/step4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="American\nVoice"
                    android:gravity="center"
                    android:textSize="10sp"
                    android:textColor="#00B894"
                    android:background="@drawable/step_bg"
                    android:padding="6dp"
                    android:alpha="0.3" />
            </LinearLayout>

            <!-- Big record button -->
            <Button
                android:id="@+id/btnRecord"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="🎤 TAP TO SPEAK"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#E94560"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <!-- Animated wave placeholder -->
            <View
                android:id="@+id/waveView"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#E94560"
                android:visibility="invisible"
                android:layout_marginBottom="16dp" />

            <!-- Status -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ready"
                android:textColor="#636E72"
                android:textSize="13sp"
                android:layout_marginBottom="20dp" />

            <!-- What you said -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#16213E"
                app:cardCornerRadius="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WHAT YOU SAID"
                        android:textColor="#636E72"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvTranscript"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Tap the button and speak in any accent..."
                        android:textColor="#B2BEC3"
                        android:textSize="15sp"
                        android:minHeight="48dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Converted American voice -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#0F2D4A"
                app:cardCornerRadius="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔊 AMERICAN VOICE OUTPUT"
                            android:textColor="#0984E3"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1" />

                        <TextView
                            android:id="@+id/tvLatency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="#FDCB6E"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvConverted"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Converted text will appear here..."
                        android:textColor="#DFE6E9"
                        android:textSize="15sp"
                        android:minHeight="48dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Latency info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pipeline: Deepgram ~100ms + Cartesia ~80ms ≈ 180ms total"
                android:textColor="#636E72"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
