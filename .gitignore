# =============================================================================
# Kiro IDE files — never ship to client
# =============================================================================
.kiro/

# =============================================================================
# Python cache & compiled bytecode
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo

# =============================================================================
# Test / CI artefacts
# =============================================================================
.pytest_cache/
.hypothesis/
.coverage
coverage.xml
htmlcov/
*.log

# =============================================================================
# Virtual environments
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# OS / editor noise
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/

# =============================================================================
# Secrets & credentials — never commit
# =============================================================================
*.env
.env
.env.*
secrets.py
credentials.json
*.pem
*.key
*.crt
*.p12
*.pfx

# Config files with live credentials
voip/smart_routing/config.ini
voip/smart_routing/ngrok.yml

# =============================================================================
# Asterisk runtime files (generated on the server, not source-controlled)
# =============================================================================
/etc/
/var/
*.conf.bak

# =============================================================================
# Build / distribution artefacts
# =============================================================================
dist/
build/
*.egg-info/
*.egg
